DATABASE_URL="postgresql://yacht_sales:yacht_sales_dev_password@localhost:55433/sme_yacht_sales?schema=public"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-please"
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"

# SecuAI 站点防护接入。未准备好真实平台地址和站点配置前保持关闭。
# 是否让 middleware 调用 SecuAI；无平台访问能力的本地演示建议保持 false。
SECUAI_ENABLED="false"
# SecuAI 平台基础地址；不要把平台 IP 硬编码到应用代码中。
SECUAI_PLATFORM_URL=""
# SecuAI 平台中创建的站点 ID。
SECUAI_SITE_ID=""
# 与站点 ID 配对的站点 ingestion key。
SECUAI_SITE_INGESTION_KEY=""
# 默认 true：SecuAI 不可用、超时或返回异常时放行站点请求，避免阻断演示。
SECUAI_FAIL_OPEN="true"
# 调用 SecuAI 检查接口的超时时间，单位毫秒。
SECUAI_TIMEOUT_MS="1500"
# SecuAI 平台侧检查接口路径。
SECUAI_CHECK_PATH="/api/v1/protection/check"
