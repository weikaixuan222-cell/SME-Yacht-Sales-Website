generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum YachtCondition {
  NEW
  USED
}

enum YachtStatus {
  DRAFT
  AVAILABLE
  SOLD
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Yacht {
  id            String          @id @default(cuid())
  name          String
  brand         String
  model         String
  year          Int
  price         Decimal         @db.Decimal(12, 2)
  length        Decimal         @db.Decimal(6, 2)
  capacity      Int
  condition     YachtCondition
  location      String
  description   String
  coverImage    String
  galleryImages String[]
  status        YachtStatus     @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  inquiries     Inquiry[]
}

model Inquiry {
  id           String   @id @default(cuid())
  yachtId      String
  customerName String
  email        String
  phone        String
  message      String
  createdAt    DateTime @default(now())
  yacht        Yacht    @relation(fields: [yachtId], references: [id], onDelete: Cascade)

  @@index([yachtId])
  @@index([createdAt])
}
